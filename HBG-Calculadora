<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Hub Games Calculator</title>
<style>
body{background:#0d0d0d;color:#fff;font-family:Arial;padding:20px}
.card{background:#181818;border:1px solid #29ff78;border-radius:10px;padding:15px;margin:10px 0}
input,select,button{width:100%;padding:10px;margin-top:6px;box-sizing:border-box}
button{background:#29ff78;color:#000;font-weight:bold}
.pre{white-space:pre-wrap}
</style>
</head>
<body>
<h1>🎯 HUB GAMES Calculator</h1>

<div class="card">
<label>Banca</label>
<input id="banca" type="number" value="50">

<label>Meta (%)</label>
<input id="meta" type="number" value="20">

<label>Ciclos</label>
<select id="ciclos">
<option value="1">1</option>
<option value="2" selected>2</option>
<option value="3">3</option>
<option value="4">4</option>
<option value="5">5</option>
</select>

<label>Operação</label>
<select id="tipo">
<option value="1">Player (1:1)</option>
<option value="0.9">Banker (0,9:1)</option>
</select>

<button id="btn">CALCULAR</button>
</div>

<div class="card pre" id="saida">Clique em CALCULAR.</div>

<script>
document.getElementById('btn').addEventListener('click', function(){

const banca = Number(document.getElementById('banca').value || 0);
const metaPerc = Number(document.getElementById('meta').value || 0);
const ciclos = Number(document.getElementById('ciclos').value || 1);
const odd = Number(document.getElementById('tipo').value || 1);

const metaTotal = banca * (metaPerc/100);
const metaCiclo = metaTotal / ciclos;

const empate1 = Math.max(metaCiclo * 0.10, 1);
const lateral1 = (metaCiclo + empate1) / odd;

const perda1 = lateral1 + empate1;

const empate2 = empate1 * 2;
const lateral2 = (perda1 + metaCiclo + empate2) / odd;

const lucroLat1 = (lateral1 * odd) - empate1;
const lucroEmp1 = empate1 * 8;

const lucroLat2 = ((lateral2 * odd) - empate2) - perda1;
const lucroEmp2 = (empate2 * 8) - perda1;

document.getElementById('saida').textContent =
`💰 Banca: R$ ${banca.toFixed(2)}
🎯 Meta Total: R$ ${metaTotal.toFixed(2)}
📈 Meta por Ciclo: R$ ${metaCiclo.toFixed(2)}

ENTRADA 1
Lateral: R$ ${lateral1.toFixed(2)}
Empate: R$ ${empate1.toFixed(2)}

ENTRADA 2 (Recuperação)
Lateral: R$ ${lateral2.toFixed(2)}
Empate: R$ ${empate2.toFixed(2)}

SIMULAÇÕES
🟢 Lateral 1ª: +R$ ${lucroLat1.toFixed(2)}
🟢 Empate 1ª: +R$ ${lucroEmp1.toFixed(2)}
🟢 Lateral 2ª: +R$ ${lucroLat2.toFixed(2)}
🟢 Empate 2ª: +R$ ${lucroEmp2.toFixed(2)}
🔴 Loss Máximo: -R$ ${(perda1+lateral2+empate2).toFixed(2)}`;
});
</script>
</body>
</html>

